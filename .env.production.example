NODE_ENV=production
PORT=3000

# 최소 32자 이상, 운영 서버마다 고유한 랜덤 문자열을 사용하세요.
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# 최초 관리자 계정 생성 화면(/admin/setup)에서 한 번 사용하는 긴 설정 키입니다.
ADMIN_SETUP_KEY=replace-with-a-long-random-setup-key

# Cafe24 VPS에서 Nginx가 X-Real-IP/X-Forwarded-For를 직접 설정할 때만 true로 둡니다.
TRUST_PROXY_HEADERS=true
